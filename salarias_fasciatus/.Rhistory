library(tidyverse)
library(janitor)
library(lubridate)
library(readxl)
library(purrr)
students <- read_tsv("studentid.txt", col_names=FALSE) %>%
rename(student_id = X1)
assignments <-
list.files() %>%
.[str_detect(., "^EVOL.*xlsx")]
num_assignments <- length(assignments)
calc_num_secs <-
function(file_name){
num_qs <-
readxl::read_xlsx(path = file_name) %>%
clean_names() %>%
select(starts_with("feedback")) %>%
ncol()
num_qs * 20
}
assignment_list <-
assignments %>%
purrr::map(function(file_name){ # iterate through each sheet name
readxl::read_xlsx(path = file_name) %>%
clean_names() %>%
separate(email,
into=c("student_id",
NA)) %>%
mutate(credit = 1,
effort = as.numeric(completion_time - start_time) / calc_num_secs(file_name),
effort = case_when(effort >= 1 ~ 1.0,
TRUE ~ effort)
) %>%
group_by(student_id) %>%
filter(effort == max(effort))
})
scores_credit <-
assignment_list %>%
map(~select(.,
student_id,
credit,
# effort
) %>%
unique() %>%
right_join(students,
by="student_id")) %>%
reduce(full_join,
by = "student_id") %>%
pivot_longer(cols = starts_with("credit"),
names_to = "lecture",
values_to = "credit") %>%
group_by(student_id) %>%
summarize(prop_credit = 100*sum(credit, na.rm=TRUE)/num_assignments)
scores_effort <-
assignment_list %>%
map(~select(.,
student_id,
# credit,
effort
) %>%
unique() %>%
right_join(students,
by="student_id")) %>%
reduce(full_join,
by = "student_id") %>%
pivot_longer(cols = starts_with("effort"),
names_to = "lecture",
values_to = "effort") %>%
group_by(student_id) %>%
summarize(prop_credit = 100*sum(effort, na.rm=TRUE)/num_assignments)
write_csv(scores_effort,"scores.csv")
setwd(dirname(rstudioapi::getActiveDocumentContext()$path))
library(tidyverse)
library(janitor)
library(lubridate)
library(readxl)
library(purrr)
students <- read_tsv("studentid.txt", col_names=FALSE) %>%
rename(student_id = X1)
assignments <- list.files() %>%
.[str_detect(., "EVOL.*xlsx")]
num_assignments <- length(assignments)
assignment_list <-
assignments %>%
purrr::map(function(file_name){ # iterate through each sheet name
readxl::read_xlsx(path = file_name) %>%
separate(Email, into=c("student_id", NA )) %>%
mutate(credit = 1)
})
scores <-
assignment_list %>%
map(~select(., student_id, credit) %>%
unique() %>%
right_join(students, by="student_id")) %>%
reduce(full_join, by = "student_id") %>%
pivot_longer(cols = starts_with("credit"),
names_to = "lecture",
values_to = "credit") %>%
group_by(student_id) %>%
summarize(prop_credit = 100*sum(credit, na.rm=TRUE)/num_assignments)
write_csv(scores,"scores.csv")

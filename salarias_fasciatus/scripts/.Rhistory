data_meth <- function(bam_meth_path,
metadata_meth_path){
#get bam file
do.call("DataFrame",
scanBam(bam_meth_path)) %>%
as_tibble %>%
dplyr::rename(read_id = qname,
chromosome_id = rname,
chromosome_id_mate = mrnm,
insert_size = isize,
seq_bam = seq) %>%
select(-mpos,
-chromosome_id_mate,
-strand) %>%
#join metadata to bam
left_join(read_tsv(metadata_meth_path,
col_names = FALSE) %>%
dplyr::rename(read_id = X1,
leading_motif_read1 = X2,
leading_motif_read2 = X3,
# seq_orig_read1 = X4,
# seq_orig_read2 = X5,
# number_ccgg_read1 = X6,
# number_ccgg_read2 = X7,
# number_caattg_read1 = X8,
# number_caattg_read2 = X9
),
by = c("read_id")) %>%
mutate(file_name = metadata_meth_path,
methylation = 1)
}
data_unmeth <- function(bam_unmeth_path,
metadata_unmeth_path){
# get bam file
do.call("DataFrame",
scanBam(bam_unmeth_path)) %>%
as_tibble %>%
dplyr::rename(read_id = qname,
chromosome_id = rname,
chromosome_id_mate = mrnm,
insert_size = isize,
seq_bam = seq) %>%
select(-mpos,
-chromosome_id_mate,
-strand) %>%
# join metadata to bam
left_join(read_tsv(metadata_unmeth_path,
col_names = FALSE) %>%
dplyr::rename(read_id = X1,
leading_motif_read1 = X2,
leading_motif_read2 = X3,
# seq_orig_read1 = X4,
# seq_orig_read2 = X5,
# number_ccgg_read1 = X6,
# number_ccgg_read2 = X7,
# number_caattg_read1 = X8,
# number_caattg_read2 = X9
) ,
by = c("read_id")) %>%
mutate(file_name = metadata_unmeth_path,
methylation = 0)
}
#
data <-
bind_rows(data_meth(bam_meth_path,
metadata_meth_path),
data_unmeth(bam_unmeth_path,
metadata_unmeth_path))
#### JOIN METH & UNMETH FILES & WRANGLE INTO SUBMISSION ####
# updated to create no intermediate files
data <-
bind_rows(data_meth(bam_meth_path,
metadata_meth_path),
data_unmeth(bam_unmeth_path,
metadata_unmeth_path)) %>%
group_by(read_id) %>%
mutate(flag_max = max(flag),
flag_min = min(flag),
reads_present_in_pair = n()) %>%
# remove reads that should have been filtered by bam filter step, but were not
filter(reads_present_in_pair == 2) %>%
mutate(read1_or_read2 = case_when(flag == flag_min ~ "read1",
flag == flag_max ~ "read2",
TRUE ~ NA_character_)) %>%
pivot_wider(names_from = read1_or_read2,
values_from = flag:qual) %>% #running this as early as possible may help speed since the df is more
# this line of code could result in loss of valid data due to trimming of the fq.gz file prior to mapping
# which could lead to minor differences in the returned restriction site positions
# need to either change trimming or add a function to cluster these resulting values, which I now do
mutate(ccgg_restriction_site_position = case_when(pos_read1 < pos_read2 ~ as.numeric(pos_read1 + insert_size_read1),
pos_read1 > pos_read2 ~ as.numeric(pos_read2),
pos_read1 == pos_read2 & insert_size_read1 > insert_size_read2 ~ as.numeric(pos_read1 + insert_size_read1),
pos_read1 == pos_read2 & insert_size_read2 > insert_size_read1 ~as.numeric(pos_read2),
TRUE ~ NA_real_),
caattg_restriction_site_position = case_when(pos_read2 < pos_read1 ~ as.numeric(pos_read2 + insert_size_read2),
pos_read2 > pos_read1 ~ as.numeric(pos_read1),
pos_read2 == pos_read1 & insert_size_read2 > insert_size_read1 ~ as.numeric(pos_read2 + insert_size_read2),
pos_read2 == pos_read1 & insert_size_read1 > insert_size_read2 ~as.numeric(pos_read1),
TRUE ~ NA_real_),
side_of_site = factor(case_when(pos_read1 < pos_read2 ~ "upstream",
pos_read1 > pos_read2 ~ "downstream",
pos_read1 == pos_read2 & insert_size_read1 > insert_size_read2 ~ "upstream",
pos_read1 == pos_read2 & insert_size_read2 > insert_size_read1 ~ "downstream",
TRUE ~ NA_character_),
levels = c("upstream",
"downstream")),
# we take advantage of 150 bp reads and no reads longer than 50bp being kept after trimming and
# round the positions to the nearest 100 to group them so that minor differences in restriction site position
# for the same restriction site are eliminated
ccgg_restriction_site_position_group = round(ccgg_restriction_site_position/ccgg_group_window, 0)*ccgg_group_window) %>%
group_by(ccgg_restriction_site_position_group,
side_of_site) %>%
# once grouped, we calculate the max and min positions associated with each group
mutate(ccgg_restriction_site_position_group_max = max(ccgg_restriction_site_position),
ccgg_restriction_site_position_group_min = min(ccgg_restriction_site_position)) %>%
# then we can define the beginning (upstream) and end (downstream) position of each CCGG site
mutate(ccgg_restriction_site_beginning_position = case_when(side_of_site == "upstream" ~ ccgg_restriction_site_position_group_max - 3,
side_of_site == "downstream" ~ ccgg_restriction_site_position_group_min - 1,
TRUE ~ NA_real_),
ccgg_restriction_site_end_position = case_when(side_of_site == "upstream" ~ ccgg_restriction_site_position_group_max + 1,
side_of_site == "downstream" ~ ccgg_restriction_site_position_group_min + 3,
TRUE ~ NA_real_),
ccgg_restriction_site_group = str_c(ccgg_restriction_site_beginning_position,
side_of_site,
sep="_")) %>%
# next, lets use R to count the number of undigested restriction sites because awk was not finding all of them
# note, this will need to be updated to use the untrimmed seqs, for now it uses the trimmed seqs
mutate(number_ccgg_bam_r_read1 = str_count(seq_bam_read1,
"CCGG"),
number_ccgg_bam_r_read2 = str_count(seq_bam_read2,
"CCGG"),
number_caattg_bam_r_read1 = str_count(seq_bam_read1,
"CAATTG"),
number_caattg_bam_r_read2 = str_count(seq_bam_read2,
"CAATTG"),
# number_ccgg_orig_r_read1 = str_count(seq_orig_read1,
#                                      "CCGG"),
# number_ccgg_orig_r_read2 = str_count(seq_orig_read2,
#                                      "CCGG"),
# diff_tsv_orig_ccgg_read1 = number_ccgg_read1 - number_ccgg_orig_r_read1,
# diff_tsv_orig_ccgg_read2 = number_ccgg_read2 - number_ccgg_orig_r_read2,
# diff_tsv_bam_ccgg_read1 = number_ccgg_read1 - number_ccgg_bam_r_read1,
# diff_tsv_bam_ccgg_read2 = number_ccgg_read2 - number_ccgg_bam_r_read2,
# diff_orig_bam_ccgg_read1 = number_ccgg_orig_r_read1 - number_ccgg_bam_r_read1,
# diff_orig_bam_ccgg_read2 = number_ccgg_orig_r_read2 - number_ccgg_bam_r_read2,
sum_ccgg_bam_r = number_ccgg_bam_r_read1 + number_ccgg_bam_r_read2,
sum_caattg_bam_r = number_caattg_bam_r_read1 + number_caattg_bam_r_read2,
#classify each read pair (fragment) by digestion status
# digestion_status = case_when(leading_motif_read1 == "AATTG" &
#                             leading_motif_read2 == "CGG" &
#                             sum_ccgg_bam_r == 0 &
#                             sum_caattg_bam_r == 0 ~ "complete_specific",
#                           leading_motif_read1 == "AATTG" &
#                             leading_motif_read2 == "CGG" &
#                             sum_ccgg_bam_r != 0 &
#                             sum_caattg_bam_r == 0 ~ "incomplete_digestion_ccgg",
#                           leading_motif_read1 == "AATTG" &
#                             leading_motif_read2 == "CGG" &
#                             sum_ccgg_bam_r == 0 &
#                             sum_caattg_bam_r != 0 ~ "incomplete_digestion_caattg",
#                           leading_motif_read1 == "AATTG" &
#                             leading_motif_read2 == "CGG" &
#                             sum_ccgg_bam_r != 0 &
#                             sum_caattg_bam_r != 0 ~ "incomplete_digestion_both",
#                           leading_motif_read1 != "AATTG" &
#                             leading_motif_read2 == "CGG" ~ "nonspecific_digestion_aattg",
#                           leading_motif_read1 == "AATTG" &
#                             leading_motif_read2 != "CGG" ~ "nonspecific_digestion_cgg",
#                           leading_motif_read1 != "AATTG" &
#                             leading_motif_read2 != "CGG" ~ "nonspecific_digestion_both",
#                           TRUE ~ NA_character_),
digestion_completeness = case_when(sum_ccgg_bam_r == 0 &
sum_caattg_bam_r == 0 ~ "complete",
sum_ccgg_bam_r != 0 &
sum_caattg_bam_r == 0 ~ "incomplete_ccgg",
sum_ccgg_bam_r == 0 &
sum_caattg_bam_r != 0 ~ "incomplete_caattg",
sum_ccgg_bam_r != 0 &
sum_caattg_bam_r != 0 ~ "incomplete_both",
TRUE ~ NA_character_),
digestion_specificity = case_when(leading_motif_read1 == "AATTG" &
leading_motif_read2 == "CGG" ~ "specific",
leading_motif_read1 != "AATTG" &
leading_motif_read2 == "CGG" ~ "nonspecific_aattg",
leading_motif_read1 == "AATTG" &
leading_motif_read2 != "CGG" ~ "nonspecific_cgg",
leading_motif_read1 != "AATTG" &
leading_motif_read2 != "CGG" ~ "nonspecific_both",
TRUE ~ NA_character_),
digestion_status = str_c(digestion_specificity,
digestion_completeness,
sep = "-"),
insert_length = abs(insert_size_read1)) %>%
select(-starts_with("insert_size_read")) %>%
group_by(ccgg_restriction_site_position_group) %>%
filter(abs(insert_length) < 800) %>%
ungroup()
View(data)
#### INITIALIZE ####
setwd(dirname(rstudioapi::getActiveDocumentContext()$path))
library(tidyverse)
library(janitor)
library(magrittr)
#### USER DEFINED VARIABLES ####
inFILE="../mkBGL/mkBGL.snpStat.gz"
numInd=81
minInd=41
maxDP=numInd*5
sb_pval=0.5
#### WRANGLE SNP STATS ####
data_snp <-
read_tsv(inFILE) %>%
clean_names() %>%
rename(chrom = chromo,
pos = position) %>%
separate(major_minor_major_minor,
into = c("pos_major",
"pos_minor",
"neg_major",
"neg_minor"),
convert = TRUE,
sep = " ") %>%
separate(sb1_sb2_sb3,
into = c("strand_bias_1",
"strand_bias_2",
"strand_bias_3"),
convert = TRUE,
sep = ":") %>%
separate(hwe_lrt_hwe_pval,
into = c("hwe_lrt",
"hwe_pval"),
convert = TRUE,
sep = ":") %>%
separate(base_q_z_base_q_pval,
into = c("base_qual_z",
"base_qual_pval"),
convert = TRUE,
sep = ":") %>%
separate(map_q_z_map_q_pval,
into = c("map_qual_z",
"map_qual_pval"),
convert = TRUE,
sep = ":") %>%
separate(edge_z_edge_pval,
into = c("edge_z",
"edge_pval"),
convert = TRUE,
sep = ":") %>%
mutate(chrom_pos = str_c(chrom,
pos,
sep = "_"),
pos_minor_prop = pos_minor / (pos_major+pos_minor),
neg_minor_prop = neg_minor / (neg_major+pos_minor)) %>%
select(chrom,
pos,
chrom_pos,
starts_with("pos_"),
starts_with("neg_"),
everything())
data_snp <-
data_snp %>%
separate(major_het_minor_het_major_het_minor_het_n_het,
into = c("pos_major_het",
"pos_minor_het",
"neg_major_het",
"neg_minor_het",
"n_het"),
convert = TRUE,
sep = " ") %>%
separate(het_stat_het_stat_pval,
into = c("het_stat",
"het_stat_pval"),
convert = TRUE,
sep = ":") %>%
mutate(pos_allele_balance = pos_minor_het / (pos_minor_het + pos_major_het),
neg_allele_balance = neg_minor_het / (neg_minor_het + neg_major_het),
allele_balance = (pos_minor_het + neg_minor_het) / (pos_minor_het + pos_major_het + neg_minor_het + neg_major_het),
rough_est_het = (pos_minor_het + pos_major_het + neg_minor_het + neg_major_het)/(pos_minor + pos_major + neg_minor + neg_major))
inFILE="../mkBGL/test03.100k.snpStat"
numInd=81
minInd=41
maxDP=numInd*5
sb_pval=0.5
#### WRANGLE SNP STATS ####
data_snp <-
read_tsv(inFILE) %>%
clean_names() %>%
rename(chrom = chromo,
pos = position) %>%
separate(major_minor_major_minor,
into = c("pos_major",
"pos_minor",
"neg_major",
"neg_minor"),
convert = TRUE,
sep = " ") %>%
separate(sb1_sb2_sb3,
into = c("strand_bias_1",
"strand_bias_2",
"strand_bias_3"),
convert = TRUE,
sep = ":") %>%
separate(hwe_lrt_hwe_pval,
into = c("hwe_lrt",
"hwe_pval"),
convert = TRUE,
sep = ":") %>%
separate(base_q_z_base_q_pval,
into = c("base_qual_z",
"base_qual_pval"),
convert = TRUE,
sep = ":") %>%
separate(map_q_z_map_q_pval,
into = c("map_qual_z",
"map_qual_pval"),
convert = TRUE,
sep = ":") %>%
separate(edge_z_edge_pval,
into = c("edge_z",
"edge_pval"),
convert = TRUE,
sep = ":") %>%
mutate(chrom_pos = str_c(chrom,
pos,
sep = "_"),
pos_minor_prop = pos_minor / (pos_major+pos_minor),
neg_minor_prop = neg_minor / (neg_major+pos_minor)) %>%
select(chrom,
pos,
chrom_pos,
starts_with("pos_"),
starts_with("neg_"),
everything())
data_snp <-
data_snp %>%
separate(major_het_minor_het_major_het_minor_het_n_het,
into = c("pos_major_het",
"pos_minor_het",
"neg_major_het",
"neg_minor_het",
"n_het"),
convert = TRUE,
sep = " ") %>%
separate(het_stat_het_stat_pval,
into = c("het_stat",
"het_stat_pval"),
convert = TRUE,
sep = ":") %>%
mutate(pos_allele_balance = pos_minor_het / (pos_minor_het + pos_major_het),
neg_allele_balance = neg_minor_het / (neg_minor_het + neg_major_het),
allele_balance = (pos_minor_het + neg_minor_het) / (pos_minor_het + pos_major_het + neg_minor_het + neg_major_het),
rough_est_het = (pos_minor_het + pos_major_het + neg_minor_het + neg_major_het)/(pos_minor + pos_major + neg_minor + neg_major))

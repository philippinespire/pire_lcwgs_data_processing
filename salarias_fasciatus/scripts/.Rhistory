y=pct_variance_explained)) +
geom_point() +
geom_line() +
labs(title = "Scree Plot")
ggsave("../plots/Sfa_scree_CHR01.png", units = "in", height = 4, width = 6)
covFile = "../PCAngsd_selection/CHR02_PCAngsd_selection_maptest_minMaf0.05.cov"
#### READ IN PCA DATA ####
C <- as.matrix(read.table(covFile))
e <- eigen(C)
data_pca <-
read_tsv(popMap,
col_names = TRUE) %>%
bind_cols(as_tibble(e$vectors)) %>%
rename_with(.cols = starts_with("V"),
.fn = ~str_replace(.,
"^V",
"PC"))
data_pca_2 <-
as_tibble(e$values) %>%
# arrange(desc(value)) %>%
mutate(pct_variance_explained = 100 * value/sum(value),
principle_component = row_number())
data_pca_2 %>%
ggplot(aes(x=principle_component,
y=pct_variance_explained)) +
geom_point() +
geom_line() +
labs(title = "Scree Plot")
